rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; 
    }

    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && (
        request.auth.token.email == 'romenusabo3@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt', 'updatedAt']) &&
             data.keys().size() >= 4 && data.keys().size() <= 5 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             (!('hasConsented' in data) || data.hasConsented is bool);
    }

    match /users/{userId} {
      allow get: if isVerified() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isVerified() && isValidId(userId) && request.auth.uid == userId &&
                    isValidUser(incoming()) &&
                    incoming().email == request.auth.token.email &&
                    incoming().role == (request.auth.token.email == 'romenusabo3@gmail.com' ? 'admin' : 'user') &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
                    
      allow update: if isVerified() && request.auth.uid == userId && isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['hasConsented', 'updatedAt']) &&
                    incoming().updatedAt == request.time &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().email == existing().email &&
                    incoming().role == existing().role;
      allow update: if isAdmin() && isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt']) &&
                    incoming().updatedAt == request.time &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().email == existing().email;
    }

    function isValidDatosOnboarding(data) {
      return data.keys().hasAll(['nombre', 'fechaNacimiento', 'horaNacimiento', 'lugarNacimiento', 'genero', 'nivelEstudios', 'rolProyecto', 'antiguedad', 'estadoTension']) &&
             data.keys().size() == 9 &&
             data.nombre is string && data.nombre.size() <= 200 &&
             data.fechaNacimiento is string && data.fechaNacimiento.size() <= 100 &&
             data.horaNacimiento is string && data.horaNacimiento.size() <= 100 &&
             data.lugarNacimiento is string && data.lugarNacimiento.size() <= 200 &&
             data.genero is string && data.genero.size() <= 100 &&
             data.nivelEstudios is string && data.nivelEstudios.size() <= 100 &&
             data.rolProyecto is string && data.rolProyecto.size() <= 200 &&
             data.antiguedad is string && data.antiguedad.size() <= 100 &&
             data.estadoTension is string && data.estadoTension.size() <= 1000;
    }

    function isValidFicha(data) {
      return data.keys().hasAll(['userId', 'datosOnboarding', 'createdAt', 'updatedAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.datosOnboarding is map && isValidDatosOnboarding(data.datosOnboarding) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             (!('manualGenerado' in data) || data.manualGenerado is string) &&
             (!('fechaGeneracion' in data) || data.fechaGeneracion is timestamp) &&
             (!('versionesAnteriores' in data) || data.versionesAnteriores is list) &&
             (!('isSeedData' in data) || data.isSeedData is bool);
    }

    match /fichas/{fichaId} {
      allow get: if isVerified() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isVerified() && (existing().userId == request.auth.uid || isAdmin());
      
      allow create: if isVerified() && isValidId(fichaId) && isValidFicha(incoming()) &&
                    incoming().userId == request.auth.uid &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
                    
      allow update: if isVerified() && isValidFicha(incoming()) &&
                    (
                      (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['datosOnboarding', 'manualGenerado', 'fechaGeneracion', 'versionesAnteriores', 'updatedAt'])) ||
                      isAdmin()
                    ) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
      
      allow delete: if isAdmin();
    }

    function isValidFichaVersion(data) {
      return data.keys().hasAll(['fichaId', 'userId', 'data', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.fichaId is string && data.fichaId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.data is map &&
             data.createdAt is timestamp;
    }

    match /fichaVersions/{versionId} {
      allow get: if isVerified() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isVerified() && (existing().userId == request.auth.uid || isAdmin());
      
      allow create: if isVerified() && isValidId(versionId) && isValidFichaVersion(incoming()) &&
                    incoming().userId == request.auth.uid &&
                    exists(/databases/$(database)/documents/fichas/$(incoming().fichaId)) &&
                    get(/databases/$(database)/documents/fichas/$(incoming().fichaId)).data.userId == request.auth.uid &&
                    incoming().createdAt == request.time;
    }

    function isValidResponse(data) {
      return data.keys().hasAll(['userId', 'step', 'message', 'sender', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.step is string && data.step.size() <= 100 &&
             data.message is string && data.message.size() <= 2000 &&
             data.sender in ['user', 'bot'] &&
             data.createdAt is timestamp;
    }

    match /responses/{responseId} {
      allow get: if isVerified() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isVerified() && (existing().userId == request.auth.uid || isAdmin());
      
      allow create: if isVerified() && isValidId(responseId) && isValidResponse(incoming()) &&
                    incoming().userId == request.auth.uid &&
                    exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                    incoming().createdAt == request.time;
    }
  }
}
